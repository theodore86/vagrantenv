<?xml version="1.0" encoding="utf-8"?>
<!--
Windows package installation through Chocolatey
https://github.com/chocolatey/choco/wiki/CommandsInstall#packagesconfig
-->
<packages>
  <package id="virtualbox" version="7.1.8" packageParameters="/NoDesktopShortcut" allowMultipleVersions="false"/>
  <package id="python3" version="3.11.0"/>
  <package id="vagrant" version="2.4.3"/>
  <package id="vscode" version="1.99.3"/>
</packages>
